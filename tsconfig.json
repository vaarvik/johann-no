{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/assets/*": ["./app/lib/assets/*"],
            "@/components/*": ["./app/lib/components/*"],
            "@/constants": ["./app/lib/constants.ts"],
            "@/services/*": ["./app/lib/services/*"],
            "@/types/*": ["./app/lib/types/*"],
            "@/*": ["./*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "./eslint.config.mjs"
    ],
    "exclude": ["node_modules"]
}
